{
  "name": "@vaibot/circuit-breaker-openclaw-plugin",
  "version": "0.1.5",
  "description": "OpenClaw plugin that enforces VAIBot governance decisions with a multi-source decision chain and circuit-breaker fallback.",
  "type": "module",
  "main": "index.ts",
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "scripts/**",
    "src/**",
    "systemd/**",
    "references/**",
    "assets/**"
  ],
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "scripts": {
    "test": "vitest run",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
