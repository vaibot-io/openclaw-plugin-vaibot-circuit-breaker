{
  "name": "@vaibot/circuit-breaker-openclaw-plugin",
  "version": "0.2.5",
  "license": "MIT",
  "description": "OpenClaw plugin that enforces VAIBot governance decisions with a multi-source decision chain and circuit-breaker fallback.",
  "keywords": [
    "openclaw",
    "claude-code",
    "codex",
    "guardrails",
    "governance",
    "ai-governance",
    "circuit-breaker",
    "vaibot",
    "audit",
    "provenance",
    "security"
  ],
  "type": "module",
  "main": "index.ts",
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "scripts/**",
    "src/plugin.ts",
    "src/openclaw-plugin-sdk.d.ts",
    "systemd/**",
    "references/**",
    "assets/**",
    "vendor/**"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:pack": "node ./scripts/verify-pack.mjs",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@vaibot/guard": "workspace:*",
    "vitest": "^2.0.0"
  }
}
